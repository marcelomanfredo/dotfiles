// Modules configuration for Waybar
{
	// Group Definitions
	"group/audio": {
		"orientation": "inherit",
		"modules": [
			"custom/media",
			"pulseaudio"
		]
	},

	"group/system": {
		"orientation": "inherit",
		"modules": [
			"cpu",
			"temperature",
			"memory"
		]
	},

	"group/g-network": {
		"orientation": "inherit",
		"modules": [
			"network"
		]
	},
	"group/infos": {
		"orientation": "inherit",
		"modules": [
			"clock",
			"custom/weather"
		]
	},

	// Modules
	"clock": {
		"locale": "en_US.UTF-8",
		"timezone": "America/Sao_Paulo",
		"format": "´É║  {:%R%n%d\/%m\/%y}",
		"tooltip-format": "<tt><span color='#ffead3' size='large' weight='bold'>¾░©ÿ  {:%B %Y}</span><small><span show='none'>{calendar}</span></small></tt>",
		"actions": {
			"on-scroll-up": "shift_down",
			"on-scroll-down": "shift_up",
			"on-click-middle": "shift_reset"
		},
		"calendar": {
			"weeks-pos": "left",
			"format": {
				"months":	"",
				"days": 	"<span color='#ecc69d'><b>{}</b></span>",
				"weeks":	"<span color='#99ffdd'><b>W{}</b></span>",
				"weekdays":	"<span color='#ffcc66'><b>{}</b></span>",
				"today":	"<span color='#ff6699'><b><u>{}</u></b></span>"
			}
		}
	},
	
	"cpu": {
        	"format": "{usage:2}% ´ïø",
	        "tooltip": true
	},

	"hyprland/window": {
		"separate-outputs": true,
		"rewrite": {
			"^(.*)Firefox$": "Firefox ¾░¿ç",
			"^(.*\\| )(.*)Discord$": "$2 Discord ¾░Ö»",
			"^.*Steam.*$": "Steam ¯┤®"
		}
	},

	"hyprland/workspaces": {
		"disable-scroll": true,
	        "all-outputs": true,
        	"warp-on-scroll": false,
		"persistent-workspaces": {
			"1": [],
			"2": []
		},
		"format": "{icon}",
	        "format-icons": {
        		"1": "´äí",
            		"2": "¾░ê╣",
            		"3": "¾░ôô",
			"5": "´î©",
            		"6": "´ç┐",
			"urgent": "´ü¬",
			"focused": "´åÆ",
			"default": "´äæ"
		}
	},

	"idle_inhibitor":{
		"format":"{icon}",
		"format-icons":{
			"activated":"´ü«",
			"deactivated":"´ü░"
		}
	},

	"memory": {
		"format": "{}% ¯┐à ",
		"tooltip-format": "¯┐à ¯¬ƒ {percentage}% | {used:0.1f}GiB of {total:0.1f}GiB - {avail:0.1f}GiB available\n¯»ï ¯¬ƒ {percentage}% | {swapUsed:0.1f}GiB of {swapTotal:0.1f}GiB - {swapAvail:0.1f}GiB available"
	},

	"network": {
		"format-ethernet": "¾░êü Ethernet",
		"format-wifi": "´ç½ {essid} ({signalStrength}%)}",
		"format-disconnected": "¾░¬Ä",
		"max-length": 20,
		"tooltip-format": "¾░®á {ipaddr}\n¾▒éç {cidr}\n¯¡í {ifname}",
		"tooltip-format-disconnected": "Disconnected!  ¾▒êÜ ¯╣╝"
	},

	"pulseaudio": {
		"format": "{volume:3}% {icon}  {format_source}",
		"format-bluetooth": "{volume}% {icon} ´èö  {format_source}",
		"format-bluetooth-muted": "¯╗¿  ´èö  {format_source}",
		"format-muted": "¯╗¿  {format_source}",
		"format-source": "´ä░",
		"format-source-muted": "´ä▒",
		"format-icons": {
			"default": ["´Çª", "´Çº", "´Ç¿"]
		},
		"scroll-step": 5.0,
		// credits: "custom/pulseaudio-cycle", available on Wiki
		"on-click": "pactl --format=json list sinks short | jq -cM --unbuffered \"[.[].name] | .[((index(\\\"$(pactl get-default-sink)\\\")+1)%length)]\" | xargs pactl set-default-sink",
		"on-click-right": "pactl --format=json list sinks short | jq -cM --unbuffered \"[.[].name] | .[((index(\\\"$(pactl get-default-sink)\\\")-1)%length)]\" | xargs pactl set-default-sink",
		"tooltip-format": "{desc}",
		"max-voume": 100
	},

	"temperature": {
		"hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
		"input-filename": "temp1_input",
		"critical-threshold": 75,
		"format-critical": "{temperatureC}┬░C ´ü▒",
		"format": "{temperatureC}┬░C ¾░Äô",
		"tooltip-format": "CPU temperature\nCurrent:\t{temperatureC}┬░C\nTreshold:\t75┬░C"
	},

	"tray": {
		"icon-size": 21,
		"spacing": 10
	},

	// Custom Modules
	"custom/arch_logo": {
		"format": "<span color='#1793D1'>´îâ </span><span color='#ffffff'><b>arch</b></span><span color='#1793D1'><b>linux</b></span>"
	},

	"custom/media": {
		"hide-empty-text": true,
		"format": "{icon} {:25}",
		"escape": true,
		"return-type": "json",
		"max-length": 25,
		"on-click": "playerctl play-pause",
		"on-middle-click": "playerctl stop",
		"on-scroll-up": "playerctl next",
		"on-scroll-down": "playerctl previous",
		"exec": "$HOME/.config/waybar/scripts/mediaplayer.py 2> /dev/null", // Script in resources/custom_modules folder
		"format-icons": { 
			"spotify": "¾░ôç",
			"firefox": "¯Öÿ",
			"chrome":  "´ë¿",
			"edge": "¾░ç®",
			"default": "¾░ØÜ"
		}
	},

	"custom/power": {
		"format" : "ÔÅ╗",
		"tooltip": false,
		"on-click": "wlogout --protocol layer-shell"
	},

	"custom/weather": {
		"exec": "python ~/.config/waybar/scripts/weather.py",
		"restart-interval": 1500,
		"return-type": "json",
		"on-click": "xdg-open https://weather.com/weather/today/l/0bbc6b68320163d2f1d618da708ea95c8c7990dd943e7994390646cd10b485bb?unit=m"
	}
}
