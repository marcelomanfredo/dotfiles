// Modules configuration for Waybar
{
	// Group Definitions
	"group/audio": {
		"orientation": "inherit",
		"modules": [
			"custom/media",
			"pulseaudio"
		]
	},
	"group/system": {
		"orientation": "inherit",
		"modules": [
			"cpu",
			"temperature",
			"memory"
		]
	},

	"group/g-network": {
		"orientation": "inherit",
		"modules": [
			"network"
		]
	},
	"group/infos": {
		"orientation": "inherit",
		"modules": [
			"clock",
			"custom/weather"
		]
	},

	// Modules
	"clock": {
		"locale": "en_US.UTF-8",
		"timezone": "America/Sao_Paulo",
		"format": "  {:%R%n%d\/%m\/%y}",
		"tooltip-format": "<tt><span show='none'>{calendar}</span></tt>",
		"actions": {
			"on-scroll-up": "shift_down",
			"on-scroll-down": "shift_up",
			"on-click-middle": "shift_reset"
		},
		"calendar": {
			"weeks-pos": "left",
            "mode": "month",
            //"mode-mon-col": 3,
			"format": {
				"months":	"<span color='#ffead3' font_size='13pt'>󰸘  {}</span>",
                //"months":	"<span color='#ffead3'>{}</span>",
				"days": 	"<span color='#ecc69d'><b>{}</b></span>",
				"weeks":	"<span color='#99ffdd'><b>W{}</b></span>",
				"weekdays":	"<span color='#ffcc66'><b>{}</b></span>",
				"today":	"<span color='#ff6699'><b><u>{}</u></b></span>"
			}
		}
	},

	"cpu": {
        	"format": "{usage:2}% ",
	        "tooltip": true
	},

	"hyprland/window": {
		"separate-outputs": true,
		"rewrite": {
			"^(.*)Firefox$": "Firefox 󰨇",
			"^(.*)Google Chrome$": "Google Chrome 󰨇",
			"^(.*\\| )(.*)Discord$": "$2 Discord 󰙯",
			"^.*Steam.*$": "Steam "
		}
	},

	"hyprland/workspaces": {
		"disable-scroll": true,
	        "all-outputs": true,
        	"warp-on-scroll": false,
		"persistent-workspaces": {
			"1": [],
			"2": []
		},
		"format": "{icon}",
	        "format-icons": {
        		"1": "",
                "2": "󰈹",
                "3": "󰓓",
                "4": "󰩃",
                "5": "",
                "6": "",
                "7": "",
                "9": "",
            "urgent": "",
			"focused": "",
			"default": ""
		}
	},

	"idle_inhibitor":{
		"format":"{icon}",
		"format-icons":{
			"activated":"",
			"deactivated":""
		}
	},

	"memory": {
		"format": "{}%  ",
		"tooltip-format": "  {percentage}% | {used:0.1f}GiB of {total:0.1f}GiB - {avail:0.1f}GiB available\n  {percentage}% | {swapUsed:0.1f}GiB of {swapTotal:0.1f}GiB - {swapAvail:0.1f}GiB available"
	},

	"network": {
		"format-ethernet": "󰈁 Ethernet",
		"format-wifi": " {essid} ({signalStrength}%)}",
		"format-disconnected": "󰪎",
		"max-length": 20,
		"tooltip-format": "󰩠 {ipaddr}\n󱂇 {cidr}\n {ifname}",
		"tooltip-format-disconnected": "Disconnected!  "
	},

	"pulseaudio": {
		"format": "{volume:3}% {icon}  {format_source}",
		"format-bluetooth": "{volume}% {icon}   {format_source}",
		"format-bluetooth-muted": "    {format_source}",
		"format-muted": "  {format_source}",
		"format-source": "",
		"format-source-muted": "",
		"format-icons": {
			"default": ["", "", ""]
		},
		"scroll-step": 5.0,
		// credits: "custom/pulseaudio-cycle", available on Wiki
        "on-click": "pactl --format=json list sinks short | jq -cM --unbuffered \"[.[].name] | .[((index(\\\"$(pactl get-default-sink)\\\")+1)%length)]\" | xargs pactl set-default-sink",
		"on-click-right": "pactl --format=json list sinks short | jq -cM --unbuffered \"[.[].name] | .[((index(\\\"$(pactl get-default-sink)\\\")-1)%length)]\" | xargs pactl set-default-sink",
        "on-click-forward": "lua ~/.config/waybar/scripts/change_sink.lua split",
        "on-click-backward": "lua ~/.config/waybar/scripts/change_sink.lua restore",
		"tooltip-format": "{desc}",
		"max-voume": 100
	},

	"temperature": {
		"hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
		"input-filename": "temp1_input",
		"critical-threshold": 75,
		"format-critical": "{temperatureC}°C ",
		"format": "{temperatureC}°C 󰎓",
		"tooltip-format": "CPU temperature\nCurrent:\t{temperatureC}°C\nTreshold:\t75°C"
	},

	"tray": {
		"icon-size": 21,
		"spacing": 10
	},

	// Custom Modules
	"custom/arch_logo": {
		"format": "<span color='#1793D1'> </span><span color='#ffffff'><b>arch</b></span><span color='#1793D1'><b>linux</b></span>"
	},

	"custom/media": {
		"hide-empty-text": true,
		"format": "{icon} {text}",
		"escape": true,
		"return-type": "json",
		"max-length": 30,
		"on-click": "playerctl play-pause",
		"on-middle-click": "playerctl stop",
		"on-scroll-up": "playerctl previous",
            "on-scroll-down": "playerctl next",
		"exec": "$HOME/.config/waybar/scripts/mediaplayer.py 2> /dev/null", // Script in resources/custom_modules folder
		"format-icons": {
			"spotify": "󰓇",
			"firefox": "",
			"chrome":  "",
			"edge": "󰇩",
			"default": "󰝚"
		}
	},

	"custom/power": {
		"format" : "⏻",
		"tooltip": false,
		"on-click": "wlogout --protocol layer-shell"
	},

	"custom/weather": {
		//"exec": "python ~/.config/waybar/scripts/weather.py",
		"exec": "~/.local/bin/weather temp way -I --city Londrina --country BR",
		"restart-interval": 1500,
		"return-type": "json",
		"on-click": "xdg-open https://weather.com/weather/today/l/0bbc6b68320163d2f1d618da708ea95c8c7990dd943e7994390646cd10b485bb?unit=m"
	}
}
